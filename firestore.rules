rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each learner's progress lives at users/{uid}/progress/{module_id}.
    // Only that learner (their own Firebase Auth uid) may read or write it —
    // no admin/shared access from the client. Everything else is denied by
    // default (the implicit fallback when no other match applies).
    match /users/{uid}/progress/{module_id} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
